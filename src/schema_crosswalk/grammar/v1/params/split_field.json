{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "crosswalk:v1:params:split_field",
  "title": "split_field params",
  "type": "object",
  "required": ["index"],
  "additionalProperties": false,
  "properties": {
    "delimiter": { "type": "string" },
    "pattern": {
      "type": "string",
      "maxLength": 200,
      "description": "Regex, run under a non-backtracking engine (see design.md 7.2). Mutually exclusive with delimiter."
    },
    "index": { "type": "integer", "minimum": 0 },
    "on_missing_index": { "enum": ["null", "fail"], "default": "null" }
  },
  "oneOf": [
    { "required": ["delimiter"] },
    { "required": ["pattern"] }
  ]
}
